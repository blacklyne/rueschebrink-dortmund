---
import { site, nav } from "../data/site";

const year = new Date().getFullYear();
---

<footer class="anthracite-bg">
  <div class="container-premium py-20 grid gap-12 md:grid-cols-2 lg:grid-cols-4">
    <div>
      <p class="font-serif-display text-2xl font-bold">
        <span class="text-gold">R</span>üschebrink
      </p>
      <p class="mt-2 text-xs uppercase tracking-[0.3em] text-gold">
        Automobile - Dortmund
      </p>
      <span class="gold-line"></span>
      <p class="text-sm text-[#D8CFC2] max-w-xs">
        Premium KFZ-Werkstatt mit Reifen-Service und exklusiver Auto-Aufbereitung.
        Familientradition in der Rüschebrinkstraße.
      </p>
    </div>

    <div>
      <p class="eyebrow">Kontakt</p>
      <ul class="mt-5 space-y-3 text-sm text-[#D8CFC2]">
        <li>
          <a
            href={`tel:${site.phoneClean}`}
            class="hover:text-gold transition-colors"
          >
            {site.phone}
          </a>
        </li>
        <li>
          <a
            href={`mailto:${site.email}`}
            class="hover:text-gold transition-colors break-all"
          >
            {site.email}
          </a>
        </li>
        <li>
          <a
            href={site.whatsapp}
            target="_blank"
            rel="noopener"
            class="hover:text-gold transition-colors"
          >
            WhatsApp-Termin
          </a>
        </li>
      </ul>
    </div>

    <div>
      <p class="eyebrow">Adresse</p>
      <address class="mt-5 not-italic text-sm text-[#D8CFC2] space-y-1">
        <p>{site.street}</p>
        <p>{site.zip} {site.city}-{site.district}</p>
        <a
          href={site.googleMapsUrl}
          target="_blank"
          rel="noopener"
          class="mt-3 inline-block text-gold hover:text-gold-light transition-colors"
        >
          Route planen →
        </a>
      </address>
      <p class="eyebrow mt-8">Öffnungszeiten</p>
      <ul class="mt-4 space-y-1 text-sm text-[#D8CFC2]">
        <li>Mo - Fr: 09:00 - 17:30</li>
        <li>Sa: 09:00 - 16:00</li>
        <li class="text-[#9A8F7F]">So: geschlossen</li>
      </ul>
    </div>

    <div>
      <p class="eyebrow">Navigation</p>
      <ul class="mt-5 space-y-2 text-sm text-[#D8CFC2]">
        {
          nav.map((item) => (
            <li>
              <a href={item.href} class="hover:text-gold transition-colors">
                {item.label}
              </a>
            </li>
          ))
        }
        <li class="pt-3 border-t border-white/10">
          <a href="/impressum/" class="hover:text-gold transition-colors">
            Impressum
          </a>
        </li>
        <li>
          <a href="/datenschutz/" class="hover:text-gold transition-colors">
            Datenschutz
          </a>
        </li>
      </ul>
    </div>
  </div>

  <div class="border-t border-white/10">
    <div
      class="container-premium flex flex-col md:flex-row items-start md:items-center justify-between gap-4 py-6 text-xs text-[#9A8F7F]"
    >
      <p>© {year} Automobile Rüschebrink. Alle Rechte vorbehalten.</p>
      <p class="flex items-center gap-2">
        <span class="star">★</span>
        <span>{site.rating.value} aus {site.rating.count} Google-Bewertungen</span>
      </p>
    </div>
  </div>
</footer>
