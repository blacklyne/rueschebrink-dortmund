---
interface Props {
  variant?: "dark" | "light";
  size?: "sm" | "md" | "lg";
}

const { size = "md" } = Astro.props;

const heightMap = {
  sm: "h-10",
  md: "h-12 md:h-14",
  lg: "h-16 md:h-20",
};
---

<a
  href="/"
  class="inline-flex items-center transition-opacity hover:opacity-85"
  aria-label="Automobile Rüschebrink - Startseite"
>
  <img
    src="/images/logo.png"
    alt="Automobile Rüschebrink"
    class={`${heightMap[size]} w-auto`}
    loading="eager"
    decoding="async"
  />
</a>
