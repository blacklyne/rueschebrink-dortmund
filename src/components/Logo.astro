---
interface Props {
  variant?: "dark" | "light";
  size?: "sm" | "md" | "lg";
}

const { variant = "dark", size = "md" } = Astro.props;

const sizeMap = {
  sm: "text-lg",
  md: "text-xl md:text-2xl",
  lg: "text-3xl md:text-4xl",
};

const colorMain = variant === "light" ? "text-cream" : "text-anthracite";
---

<a
  href="/"
  class={`group inline-flex flex-col leading-none ${sizeMap[size]} font-serif-display font-bold tracking-tight ${colorMain}`}
  aria-label="Automobile Rüschebrink - Startseite"
>
  <span class="flex items-baseline gap-[2px]">
    <span class="transition-colors duration-300 group-hover:text-gold">R</span>
    <span>üschebrink</span>
  </span>
  <span class="mt-[2px] font-sans-ui text-[0.55em] font-medium tracking-[0.3em] uppercase text-gold">
    Automobile - Dortmund
  </span>
</a>
