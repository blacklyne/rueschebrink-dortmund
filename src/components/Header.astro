---
import Logo from "./Logo.astro";
import { site, nav } from "../data/site";

const path = Astro.url.pathname;
---

<header
  id="site-header"
  class="sticky top-0 z-50 border-b border-[#E8E0D3] bg-cream/95 backdrop-blur-md"
>
  <div class="container-premium flex items-center justify-between gap-6 py-3">
    <Logo size="md" />

    <nav class="hidden lg:flex items-center gap-8" aria-label="Hauptnavigation">
      {
        nav.map((item) => (
          <a
            href={item.href}
            class={`nav-link ${path === item.href ? "is-active" : ""}`}
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="hidden md:flex items-center gap-3">
      <a
        href={`tel:${site.phoneClean}`}
        class="btn-primary text-xs px-5 py-3"
        aria-label="Jetzt anrufen"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"
          ></path>
        </svg>
        Anrufen
      </a>
      <a
        href={site.whatsapp}
        target="_blank"
        rel="noopener"
        class="btn-secondary text-xs px-5 py-3"
      >
        Termin
      </a>
    </div>

    <button
      id="mobile-menu-toggle"
      class="lg:hidden flex flex-col gap-[5px] p-2"
      aria-label="Menü öffnen"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span class="block w-6 h-[2px] bg-anthracite transition-transform"></span>
      <span class="block w-6 h-[2px] bg-anthracite transition-opacity"></span>
      <span class="block w-6 h-[2px] bg-anthracite transition-transform"></span>
    </button>
  </div>

  <div
    id="mobile-menu"
    class="lg:hidden hidden border-t border-[#E8E0D3] bg-cream"
  >
    <nav class="container-premium flex flex-col gap-4 py-6" aria-label="Mobile Navigation">
      {
        nav.map((item) => (
          <a
            href={item.href}
            class={`text-base font-medium py-2 border-b border-[#E8E0D3] ${path === item.href ? "text-gold" : "text-anthracite"}`}
          >
            {item.label}
          </a>
        ))
      }
      <div class="flex flex-col gap-3 pt-3">
        <a href={`tel:${site.phoneClean}`} class="btn-primary text-xs">
          Anrufen - {site.phoneDisplay}
        </a>
        <a
          href={site.whatsapp}
          target="_blank"
          rel="noopener"
          class="btn-secondary text-xs"
        >
          Termin per WhatsApp
        </a>
      </div>
    </nav>
  </div>
</header>

<script is:inline>
  const toggle = document.getElementById("mobile-menu-toggle");
  const menu = document.getElementById("mobile-menu");
  if (toggle && menu) {
    toggle.addEventListener("click", () => {
      const isOpen = menu.classList.toggle("hidden") === false;
      toggle.setAttribute("aria-expanded", String(isOpen));
    });
  }
</script>
