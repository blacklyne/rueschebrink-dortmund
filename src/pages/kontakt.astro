---
import Layout from "../layouts/Layout.astro";
import PageHero from "../components/PageHero.astro";
import { site } from "../data/site";
---

<Layout
  title="Kontakt - Termin vereinbaren"
  description="Kontakt zu Automobile Rüschebrink in Dortmund-Wambel. Telefon, WhatsApp und E-Mail. Termin vereinbaren oder Beratung anfragen."
  pageType="ContactPage"
>
  <PageHero
    eyebrow="Kontakt"
    title="Termin gewünscht?"
    highlight="Persönlich. Direkt."
    subtitle="Wir sind über alle Kanäle erreichbar. Wählen Sie, was Ihnen am liebsten ist."
    image="/images/werkstatt-hexagon.png"
  />

  <section class="bg-cream py-20 md:py-28">
    <div class="container-premium">
      <div class="max-w-2xl">
        <p class="eyebrow">Direktkontakt</p>
        <h2 class="mt-4 font-serif-display text-3xl md:text-5xl font-bold">
          Drei Wege.<br /><span class="text-gold">Eine Antwort.</span>
        </h2>
        <span class="gold-line"></span>
        <p class="text-gray-700">
          Telefon, WhatsApp oder E-Mail - wir melden uns persönlich, in der Regel
          innerhalb eines Werktags.
        </p>
      </div>

      <div class="mt-14 grid gap-6 md:grid-cols-3">
        <a
          href={`tel:${site.phoneClean}`}
          class="premium-card group flex flex-col"
        >
          <div class="flex h-14 w-14 items-center justify-center border border-gold text-gold transition-colors group-hover:bg-gold group-hover:text-white">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
          </div>
          <p class="mt-6 text-xs uppercase tracking-[0.25em] text-gold">Telefon</p>
          <p class="mt-2 font-serif-display text-2xl font-bold">{site.phone}</p>
          <span class="gold-line"></span>
          <p class="text-gray-700 text-sm">
            Direkt erreichbar während der Öffnungszeiten - Mo - Fr 09:00 - 17:30, Sa 09:00 - 16:00 Uhr.
          </p>
          <p class="mt-6 text-xs uppercase tracking-[0.22em] text-gold">Jetzt anrufen →</p>
        </a>

        <a
          href={site.whatsapp}
          target="_blank"
          rel="noopener"
          class="premium-card group flex flex-col"
        >
          <div class="flex h-14 w-14 items-center justify-center border border-gold text-gold transition-colors group-hover:bg-gold group-hover:text-white">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.198-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"></path></svg>
          </div>
          <p class="mt-6 text-xs uppercase tracking-[0.25em] text-gold">WhatsApp</p>
          <p class="mt-2 font-serif-display text-2xl font-bold">Termin per Chat</p>
          <span class="gold-line"></span>
          <p class="text-gray-700 text-sm">
            Beschreiben Sie Ihr Anliegen, schicken Sie gerne ein Foto - wir antworten
            in Ruhe, sobald wir in der Werkstatt frei haben.
          </p>
          <p class="mt-6 text-xs uppercase tracking-[0.22em] text-gold">Chat öffnen →</p>
        </a>

        <a
          href={`mailto:${site.email}`}
          class="premium-card group flex flex-col"
        >
          <div class="flex h-14 w-14 items-center justify-center border border-gold text-gold transition-colors group-hover:bg-gold group-hover:text-white">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          </div>
          <p class="mt-6 text-xs uppercase tracking-[0.25em] text-gold">E-Mail</p>
          <p class="mt-2 font-serif-display text-lg font-bold break-all">{site.email}</p>
          <span class="gold-line"></span>
          <p class="text-gray-700 text-sm">
            Längere Anfragen, Angebote oder Anhänge - wir antworten in der Regel
            innerhalb eines Werktags.
          </p>
          <p class="mt-6 text-xs uppercase tracking-[0.22em] text-gold">Mail schreiben →</p>
        </a>
      </div>
    </div>
  </section>

  <section class="bg-white py-20 md:py-28">
    <div class="container-premium grid lg:grid-cols-2 gap-12 items-start">
      <div>
        <p class="eyebrow">Standort</p>
        <h2 class="mt-4 font-serif-display text-3xl md:text-5xl font-bold">
          Rüschebrinkstraße 55<br /><span class="text-gold">Dortmund-Wambel</span>
        </h2>
        <span class="gold-line"></span>

        <div class="space-y-6 text-sm">
          <div>
            <p class="text-xs uppercase tracking-[0.22em] text-gold">Adresse</p>
            <p class="mt-2 font-serif-display text-lg">
              {site.street}<br />{site.zip} {site.city}-{site.district}
            </p>
          </div>

          <div>
            <p class="text-xs uppercase tracking-[0.22em] text-gold">Öffnungszeiten</p>
            <ul class="mt-2 space-y-1">
              <li class="flex justify-between max-w-xs"><span>Montag - Freitag</span><span>09:00 - 17:30</span></li>
              <li class="flex justify-between max-w-xs text-gold font-semibold"><span>Samstag</span><span>09:00 - 16:00</span></li>
              <li class="flex justify-between max-w-xs text-gray-700"><span>Sonntag</span><span>geschlossen</span></li>
            </ul>
            <p class="mt-3 text-xs text-gold">
              Samstag geöffnet - unser Plus für Berufstätige.
            </p>
          </div>
        </div>

        <a
          href={site.googleMapsUrl}
          target="_blank"
          rel="noopener"
          class="btn-primary mt-8"
        >
          Route mit Google Maps
        </a>
      </div>

      <div class="image-stack-card relative aspect-square lg:aspect-[4/5] border border-[#E8E0D3]">
        <iframe
          src="https://maps.google.com/maps?q=R%C3%BCschebrinkstra%C3%9Fe%2055%2C%2044143%20Dortmund&t=&z=15&ie=UTF8&iwloc=&output=embed"
          width="100%"
          height="100%"
          style="border:0;"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Karte zu Automobile Rüschebrink"
          class="absolute inset-0"></iframe>
      </div>
    </div>
  </section>
</Layout>
