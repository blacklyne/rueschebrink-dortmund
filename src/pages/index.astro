---
import Layout from "../layouts/Layout.astro";
import TrustBar from "../components/TrustBar.astro";
import CTAFooterBlock from "../components/CTAFooterBlock.astro";
import { site, reviews } from "../data/site";

const services = [
  {
    icon: "wrench",
    title: "KFZ-Werkstatt",
    text: "Reparatur, Wartung, HU-Vorbereitung und Diagnose - alle Marken, faire Preise.",
    href: "/werkstatt/",
  },
  {
    icon: "tire",
    title: "Reifen-Service",
    text: "Reifenwechsel in unter 30 Minuten, schneller Reifenkauf und sichere Einlagerung.",
    href: "/reifen/",
  },
  {
    icon: "sparkle",
    title: "Premium-Aufbereitung",
    text: "Innen, außen oder komplett - inklusive monatlichem Aufbereitungs-Abo.",
    href: "/aufbereitung/",
  },
];

const reasons = [
  {
    title: "Familientradition",
    text: "Die Rüschebrinkstraße trägt unseren Namen. Persönliche Betreuung, generationsübergreifend.",
  },
  {
    title: "Faire Preise",
    text: "Transparente Kalkulation ohne versteckte Kosten - vom Reifenwechsel bis zur Aufbereitung.",
  },
  {
    title: "Schnelle Bearbeitung",
    text: "Reifenwechsel oft in unter 30 Minuten. Termine werden eingehalten.",
  },
  {
    title: "Samstag geöffnet",
    text: "Wir sind auch am Samstag von 09:00 - 16:00 Uhr für Sie da.",
  },
];
---

<Layout
  title="Premium KFZ-Werkstatt"
  description="Premium KFZ-Werkstatt in Dortmund-Wambel. Werkstatt, Reifen-Service und monatliches Auto-Aufbereitungs-Abo. Familientradition in der Rüschebrinkstraße. 4.8 Sterne aus 18 Bewertungen."
>
  <section class="relative isolate overflow-hidden">
    <div class="absolute inset-0 -z-10">
      <img
        src="https://images.unsplash.com/photo-1492144534655-ae79c964c9d7?auto=format&fit=crop&w=2400&q=80"
        alt=""
        class="h-full w-full object-cover"
        loading="eager"
        fetchpriority="high"
      />
      <div class="hero-overlay"></div>
    </div>

    <div class="container-premium py-28 md:py-40 lg:py-48 text-cream">
      <p class="eyebrow text-gold-light">{site.tagline}</p>
      <h1
        class="mt-6 font-serif-display text-4xl md:text-6xl lg:text-7xl font-bold text-cream max-w-4xl leading-[1.05] text-shadow-soft"
      >
        Ihr Fahrzeug.<br />
        <span class="text-gold">Verdient Premium-Service.</span>
      </h1>
      <p
        class="mt-6 max-w-xl text-base md:text-lg text-[#E8E0D3] text-shadow-soft"
      >
        Werkstatt, Reifen und exklusive Auto-Aufbereitung - alles aus einer Hand.
        4.8 Sterne aus 18 Google-Bewertungen.
      </p>

      <div class="mt-10 flex flex-col sm:flex-row gap-4">
        <a href={site.whatsapp} target="_blank" rel="noopener" class="btn-secondary">
          Termin vereinbaren
        </a>
        <a
          href={`tel:${site.phoneClean}`}
          class="btn-outline-gold text-cream border-cream hover:bg-cream hover:text-anthracite"
        >
          {site.phoneDisplay}
        </a>
      </div>

      <div class="mt-12 inline-flex items-center gap-3 px-5 py-3 border border-gold/40 bg-anthracite/60 backdrop-blur-sm">
        <span class="star text-lg">★★★★★</span>
        <span class="text-sm text-cream/90">
          <strong class="text-gold">{site.rating.value}</strong> aus {site.rating.count} Google-Bewertungen
        </span>
      </div>

      <p class="mt-8 text-xs uppercase tracking-[0.25em] text-gold-light">
        Familientradition in der Rüschebrinkstraße - Dortmund-Wambel
      </p>
    </div>
  </section>

  <TrustBar />

  <section class="bg-cream py-20 md:py-28">
    <div class="container-premium">
      <div class="max-w-2xl">
        <p class="eyebrow">Unsere Leistungen</p>
        <h2 class="mt-4 font-serif-display text-3xl md:text-5xl font-bold">
          Drei Bereiche.<br />
          <span class="text-gold">Ein Standard: Premium.</span>
        </h2>
        <span class="gold-line"></span>
        <p class="text-gray-700">
          Vom Reifenwechsel bis zur Komplett-Aufbereitung - bei uns erhalten Sie
          alle Leistungen rund um Ihr Fahrzeug aus einer Hand.
        </p>
      </div>

      <div class="mt-14 grid gap-6 md:grid-cols-3">
        {
          services.map((s) => (
            <a href={s.href} class="premium-card group block">
              <div class="flex h-12 w-12 items-center justify-center border border-gold text-gold transition-colors group-hover:bg-gold group-hover:text-white">
                {s.icon === "wrench" && (
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z" />
                  </svg>
                )}
                {s.icon === "tire" && (
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <circle cx="12" cy="12" r="10" />
                    <circle cx="12" cy="12" r="4" />
                    <path d="M12 2v4M12 18v4M2 12h4M18 12h4" />
                  </svg>
                )}
                {s.icon === "sparkle" && (
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M12 3v3M12 18v3M3 12h3M18 12h3M5.6 5.6l2.1 2.1M16.3 16.3l2.1 2.1M5.6 18.4l2.1-2.1M16.3 7.7l2.1-2.1" />
                  </svg>
                )}
              </div>
              <h3 class="mt-6 font-serif-display text-2xl font-bold">{s.title}</h3>
              <span class="gold-line"></span>
              <p class="text-gray-700">{s.text}</p>
              <p class="mt-6 text-xs uppercase tracking-[0.22em] text-gold flex items-center gap-2 group-hover:gap-3 transition-all">
                Mehr erfahren →
              </p>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <section class="anthracite-bg relative overflow-hidden">
    <div class="absolute inset-0 -z-0 opacity-30">
      <img
        src="https://images.unsplash.com/photo-1607860108855-64acf2078ed9?auto=format&fit=crop&w=2000&q=80"
        alt=""
        class="h-full w-full object-cover"
        loading="lazy"
      />
      <div class="absolute inset-0 bg-anthracite/70"></div>
    </div>

    <div class="container-premium relative py-20 md:py-32 grid lg:grid-cols-2 gap-12 items-center">
      <div>
        <p class="eyebrow text-gold-light">Premium-USP</p>
        <h2 class="mt-4 font-serif-display text-3xl md:text-5xl font-bold text-cream">
          Monatliche Aufbereitung.<br />
          <span class="text-gold">Auto wie am ersten Tag.</span>
        </h2>
        <span class="gold-line"></span>
        <p class="text-[#D8CFC2] max-w-lg">
          Unser monatliches Aufbereitungs-Abo. Innen und außen, mit Hand und Hingabe.
          Ihr Fahrzeug behält Wert, Glanz und Frische - ohne Aufwand für Sie.
        </p>

        <ul class="mt-8 space-y-3 text-cream/90">
          <li class="flex gap-3"><span class="text-gold">→</span> Über 30 Kunden im Monatsabo</li>
          <li class="flex gap-3"><span class="text-gold">→</span> Innen-, Außen- oder Komplett-Aufbereitung</li>
          <li class="flex gap-3"><span class="text-gold">→</span> Hochwertige Pflegeprodukte, sorgfältige Handarbeit</li>
          <li class="flex gap-3"><span class="text-gold">→</span> Werterhalt für Ihr Fahrzeug</li>
        </ul>

        <a href="/aufbereitung/" class="btn-secondary mt-10">
          Aufbereitung entdecken
        </a>
      </div>

      <div class="relative aspect-[4/5] overflow-hidden border border-gold/30">
        <img
          src="https://images.unsplash.com/photo-1601362840469-51e4d8d58785?auto=format&fit=crop&w=1200&q=80"
          alt="Premium Auto-Aufbereitung - polierter Lack glänzt im Licht"
          class="absolute inset-0 h-full w-full object-cover"
          loading="lazy"
        />
        <div class="absolute bottom-0 inset-x-0 bg-gradient-to-t from-anthracite to-transparent p-6">
          <p class="text-xs uppercase tracking-[0.25em] text-gold-light">
            Aufbereitungs-Abo
          </p>
          <p class="font-serif-display text-2xl text-cream">
            Wie neu. Jeden Monat.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-cream-subtle py-20 md:py-28">
    <div class="container-premium">
      <div class="max-w-3xl mx-auto text-center">
        <p class="eyebrow justify-center">Was Kundinnen und Kunden sagen</p>
        <h2 class="mt-4 font-serif-display text-3xl md:text-5xl font-bold">
          <span class="text-gold">4.8 Sterne.</span> 18 Stimmen.
        </h2>
        <span class="gold-line-centered"></span>
      </div>

      <div class="mt-14 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {
          reviews.slice(0, 3).map((r) => (
            <article class="premium-card flex flex-col">
              <div class="flex gap-1 text-gold mb-4">★★★★★</div>
              <p class="text-gray-700 italic leading-relaxed flex-grow">"{r.quote}"</p>
              <div class="mt-6 pt-6 border-t border-[#E8E0D3]">
                <p class="font-semibold text-anthracite">{r.author}</p>
                <p class="text-xs uppercase tracking-[0.18em] text-gold mt-1">
                  {r.label}
                </p>
              </div>
            </article>
          ))
        }
      </div>

      <div class="mt-12 text-center">
        <a
          href={site.googleMapsUrl}
          target="_blank"
          rel="noopener"
          class="btn-outline-gold"
        >
          Alle Bewertungen auf Google
        </a>
      </div>
    </div>
  </section>

  <section class="bg-white py-20 md:py-28">
    <div class="container-premium grid lg:grid-cols-2 gap-12 items-center">
      <div class="relative aspect-[4/3] overflow-hidden order-2 lg:order-1">
        <img
          src="https://images.unsplash.com/photo-1486262715619-67b85e0b08d3?auto=format&fit=crop&w=1400&q=80"
          alt="Premium-Fahrzeug in moderner Werkstatt"
          class="h-full w-full object-cover"
          loading="lazy"
        />
      </div>
      <div class="order-1 lg:order-2">
        <p class="eyebrow">Warum Rüschebrink?</p>
        <h2 class="mt-4 font-serif-display text-3xl md:text-5xl font-bold">
          Premium-Service.<br />
          <span class="text-gold">Persönlich. Verlässlich.</span>
        </h2>
        <span class="gold-line"></span>

        <ul class="mt-8 space-y-6">
          {
            reasons.map((r) => (
              <li class="flex gap-4">
                <span class="text-gold text-xl leading-none">✓</span>
                <div>
                  <p class="font-serif-display text-xl font-bold">{r.title}</p>
                  <p class="text-gray-700">{r.text}</p>
                </div>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </section>

  <section class="bg-cream py-20 md:py-28">
    <div class="container-premium grid lg:grid-cols-2 gap-12 items-center">
      <div>
        <p class="eyebrow">Standort</p>
        <h2 class="mt-4 font-serif-display text-3xl md:text-5xl font-bold">
          In der Rüschebrinkstraße.<br />
          <span class="text-gold">Mitten in Dortmund-Wambel.</span>
        </h2>
        <span class="gold-line"></span>
        <p class="text-gray-700">
          Die Straße trägt unseren Namen. Familientradition, gewachsen über Generationen.
        </p>

        <div class="mt-8 space-y-4 text-sm">
          <div>
            <p class="text-xs uppercase tracking-[0.22em] text-gold">Adresse</p>
            <p class="mt-1 font-serif-display text-lg">
              {site.street}, {site.zip} {site.city}-{site.district}
            </p>
          </div>
          <div>
            <p class="text-xs uppercase tracking-[0.22em] text-gold">Öffnungszeiten</p>
            <p class="mt-1">Mo - Fr 09:00 - 17:30 Uhr</p>
            <p>Sa 09:00 - 16:00 Uhr</p>
          </div>
          <div>
            <p class="text-xs uppercase tracking-[0.22em] text-gold">Telefon</p>
            <p class="mt-1">
              <a
                href={`tel:${site.phoneClean}`}
                class="font-serif-display text-lg hover:text-gold"
              >
                {site.phone}
              </a>
            </p>
          </div>
        </div>

        <a
          href={site.googleMapsUrl}
          target="_blank"
          rel="noopener"
          class="btn-primary mt-8"
        >
          Route mit Google Maps
        </a>
      </div>

      <div class="relative aspect-square lg:aspect-[4/5] overflow-hidden border border-[#E8E0D3]">
        <iframe
          src="https://maps.google.com/maps?q=R%C3%BCschebrinkstra%C3%9Fe%2055%2C%2044143%20Dortmund&t=&z=15&ie=UTF8&iwloc=&output=embed"
          width="100%"
          height="100%"
          style="border:0;"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Karte zu Automobile Rüschebrink"
          class="absolute inset-0"></iframe>
      </div>
    </div>
  </section>

  <CTAFooterBlock />
</Layout>
