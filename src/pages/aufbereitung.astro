---
import Layout from "../layouts/Layout.astro";
import PageHero from "../components/PageHero.astro";
import CTAFooterBlock from "../components/CTAFooterBlock.astro";
import { site, reviews } from "../data/site";

const packages = [
  {
    title: "Innen-Aufbereitung",
    text: "Staub, Schmutz und Gerüche raus. Sitze, Polster, Cockpit, Teppiche - alles gründlich.",
    bullets: [
      "Staubsaugen aller Bereiche",
      "Kunststoff- und Lederpflege",
      "Polsterreinigung bei Bedarf",
      "Geruchsneutralisierung",
    ],
  },
  {
    title: "Außen-Aufbereitung",
    text: "Lack, Felgen, Scheiben, Gummis - mit Hand und Hingabe in Form gebracht.",
    bullets: [
      "Handwäsche mit Premium-Shampoo",
      "Felgenreinigung",
      "Lackversiegelung",
      "Gummi- und Kunststoffpflege",
    ],
  },
  {
    title: "Komplett-Aufbereitung",
    text: "Innen und außen, kombiniert. Das volle Programm für Werterhalt und Premium-Gefühl.",
    bullets: [
      "Komplette Innenreinigung",
      "Außenwäsche und Versiegelung",
      "Motorraumreinigung optional",
      "Lackvorbereitung optional",
    ],
  },
];

const aboReview = reviews[2];
---

<Layout
  title="Premium Auto-Aufbereitung Dortmund"
  description="Premium Auto-Aufbereitung in Dortmund-Wambel. Innen, außen, komplett. Monatliches Aufbereitungs-Abo - Ihr Auto fühlt sich immer wie neu an."
>
  <PageHero
    eyebrow="Premium-Aufbereitung"
    title="Ihr Auto."
    highlight="Wie am ersten Tag."
    subtitle="Innen-, Außen- oder Komplett-Aufbereitung - mit Sorgfalt, hochwertigen Produkten und einem Auge fürs Detail."
    image="https://images.unsplash.com/photo-1607860108855-64acf2078ed9?auto=format&fit=crop&w=2400&q=80"
  />

  <section class="anthracite-bg relative overflow-hidden">
    <div class="absolute inset-0 -z-0 opacity-25">
      <img
        src="https://images.unsplash.com/photo-1551830820-330a71b99659?auto=format&fit=crop&w=2000&q=80"
        alt=""
        class="h-full w-full object-cover"
        loading="lazy"
      />
      <div class="absolute inset-0 bg-anthracite/70"></div>
    </div>

    <div class="container-premium relative py-20 md:py-32 grid lg:grid-cols-2 gap-12 items-center">
      <div>
        <p class="eyebrow text-gold-light">Unser Premium-USP</p>
        <h2 class="mt-4 font-serif-display text-3xl md:text-5xl font-bold text-cream">
          Das Aufbereitungs-Abo.<br />
          <span class="text-gold">Monatlich. Mühelos.</span>
        </h2>
        <span class="gold-line"></span>
        <p class="text-[#D8CFC2] max-w-lg">
          Über 30 Kunden lassen ihr Fahrzeug bei uns monatlich aufbereiten.
          Sie sparen Zeit, behalten den Werterhalt und genießen den Moment,
          jedes Mal in ein Auto einzusteigen, das sich wie neu anfühlt.
        </p>

        <ul class="mt-8 space-y-3 text-cream/90">
          <li class="flex gap-3"><span class="text-gold">→</span> Fester Monatspreis - keine Überraschungen</li>
          <li class="flex gap-3"><span class="text-gold">→</span> Bevorzugte Terminvergabe</li>
          <li class="flex gap-3"><span class="text-gold">→</span> Werterhalt für Leasing und Wiederverkauf</li>
          <li class="flex gap-3"><span class="text-gold">→</span> Persönliche Betreuung von Termin zu Termin</li>
        </ul>

        <div class="mt-10 flex flex-col sm:flex-row gap-4">
          <a
            href={site.whatsapp}
            target="_blank"
            rel="noopener"
            class="btn-secondary"
          >
            Abo anfragen
          </a>
          <a
            href={`tel:${site.phoneClean}`}
            class="btn-outline-gold text-cream border-cream hover:bg-cream hover:text-anthracite"
          >
            {site.phoneDisplay}
          </a>
        </div>
      </div>

      <div class="grid grid-cols-2 gap-4">
        <div class="aspect-[3/4] overflow-hidden border border-gold/20">
          <img
            src="https://images.unsplash.com/photo-1605559424843-9e4c228bf1c2?auto=format&fit=crop&w=900&q=80"
            alt="Hand poliert glänzenden Lack"
            class="h-full w-full object-cover"
            loading="lazy"
          />
        </div>
        <div class="aspect-[3/4] overflow-hidden border border-gold/20 mt-12">
          <img
            src="https://images.unsplash.com/photo-1601362840469-51e4d8d58785?auto=format&fit=crop&w=900&q=80"
            alt="Detailaufnahme eines aufbereiteten Fahrzeugs"
            class="h-full w-full object-cover"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <section class="bg-cream py-20 md:py-28">
    <div class="container-premium">
      <div class="max-w-2xl">
        <p class="eyebrow">Pakete</p>
        <h2 class="mt-4 font-serif-display text-3xl md:text-5xl font-bold">
          Drei Pakete.<br /><span class="text-gold">Ein Ergebnis: Premium.</span>
        </h2>
        <span class="gold-line"></span>
        <p class="text-gray-700">
          Wählen Sie zwischen Innen, Außen oder Komplett. Preise auf Anfrage,
          abgestimmt auf Größe, Zustand und Wunschumfang.
        </p>
      </div>

      <div class="mt-14 grid gap-6 md:grid-cols-3">
        {
          packages.map((p, i) => (
            <article class="premium-card">
              <p class="text-gold text-xs uppercase tracking-[0.25em]">
                Paket {String(i + 1).padStart(2, "0")}
              </p>
              <h3 class="mt-3 font-serif-display text-2xl font-bold">{p.title}</h3>
              <span class="gold-line"></span>
              <p class="text-gray-700">{p.text}</p>
              <ul class="mt-6 space-y-2 text-sm text-gray-700">
                {p.bullets.map((b) => (
                  <li class="flex gap-2"><span class="text-gold">✓</span> {b}</li>
                ))}
              </ul>
              <a
                href={site.whatsapp}
                target="_blank"
                rel="noopener"
                class="mt-6 inline-block text-xs uppercase tracking-[0.25em] text-gold hover:text-gold-dark"
              >
                Preis anfragen →
              </a>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="bg-white py-20 md:py-28">
    <div class="container-premium grid lg:grid-cols-2 gap-12 items-center">
      <div>
        <p class="eyebrow">Vor &amp; Nach</p>
        <h2 class="mt-4 font-serif-display text-3xl md:text-5xl font-bold">
          Der Unterschied.<br /><span class="text-gold">Mit Auge sichtbar.</span>
        </h2>
        <span class="gold-line"></span>
        <p class="text-gray-700">
          Lack, der wieder leuchtet. Polster, die frisch riechen. Felgen, die glänzen.
          Wir zeigen Ihnen das Ergebnis - Vor- und Nachbilder gerne auf Anfrage.
        </p>
        <p class="mt-6 text-sm text-gray-700">
          <em>Platzhalter: Vor-/Nach-Bilder vom Kunden ergänzen.</em>
        </p>
      </div>

      <div class="grid grid-cols-2 gap-4">
        <div class="relative aspect-square overflow-hidden">
          <img
            src="https://images.unsplash.com/photo-1605559424843-9e4c228bf1c2?auto=format&fit=crop&w=900&q=80"
            alt="Vor der Aufbereitung"
            class="h-full w-full object-cover grayscale"
            loading="lazy"
          />
          <span class="absolute top-3 left-3 px-2 py-1 bg-anthracite text-cream text-xs uppercase tracking-[0.2em]">Vorher</span>
        </div>
        <div class="relative aspect-square overflow-hidden">
          <img
            src="https://images.unsplash.com/photo-1542362567-b07e54358753?auto=format&fit=crop&w=900&q=80"
            alt="Nach der Aufbereitung"
            class="h-full w-full object-cover"
            loading="lazy"
          />
          <span class="absolute top-3 left-3 px-2 py-1 bg-gold text-white text-xs uppercase tracking-[0.2em]">Nachher</span>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-cream-subtle py-20 md:py-28">
    <div class="container-premium max-w-3xl mx-auto text-center">
      <p class="eyebrow justify-center">Aus dem Aufbereitungs-Abo</p>
      <p class="mt-6 font-serif-display text-2xl md:text-3xl italic leading-relaxed text-anthracite">
        "{aboReview.quote}"
      </p>
      <span class="gold-line-centered"></span>
      <p class="text-xs uppercase tracking-[0.25em] text-gold">{aboReview.author}</p>
    </div>
  </section>

  <CTAFooterBlock
    title="Bereit für das Premium-Erlebnis?"
    subtitle="Aufbereitung einmalig oder monatlich - schreiben Sie uns über WhatsApp oder rufen Sie an."
  />
</Layout>
