---
import Layout from "../layouts/Layout.astro";
import PageHero from "../components/PageHero.astro";
import CTAFooterBlock from "../components/CTAFooterBlock.astro";
import { site, reviews } from "../data/site";

const services = [
  {
    title: "Reifenwechsel",
    text: "Sommer-, Winter- und Ganzjahresreifen - oft in unter 30 Minuten gewechselt und ausgewuchtet.",
  },
  {
    title: "Reifenverkauf",
    text: "Alle namhaften Marken zu fairen Preisen. Schnelle Bestellung, kurze Lieferzeiten.",
  },
  {
    title: "Reifeneinlagerung",
    text: "Trocken, sauber, sicher. Ihre Saisonreifen sind bei uns bestens aufgehoben.",
  },
  {
    title: "Auswuchten",
    text: "Hochpräzises Auswuchten für vibrationsfreie Fahrt und gleichmäßigen Reifenverschleiß.",
  },
  {
    title: "RDKS-Service",
    text: "Reifendruckkontrollsysteme prüfen, anlernen, ersetzen - inklusive Ventil-Service.",
  },
  {
    title: "Reifenberatung",
    text: "Wir empfehlen genau das, was zu Ihrem Fahrprofil passt - ehrlich und ohne Druck.",
  },
];

const reifenReview = reviews[1];
---

<Layout
  title="Reifen Dortmund - Reifenwechsel, Verkauf, Einlagerung"
  description="Reifenwechsel in unter 30 Minuten in Dortmund-Wambel. Reifenverkauf, Einlagerung, Auswuchten. Schnelle Bestellung zu fairen Preisen."
>
  <PageHero
    eyebrow="Reifen-Service"
    title="Reifen-Service."
    highlight="In unter 30 Minuten."
    subtitle="Reifenwechsel, Reifenverkauf und sichere Einlagerung. Schnelle Bestellung, faire Preise, sauberes Handwerk."
    image="/images/reifen-werkstatt.png"
  />

  <section class="bg-cream py-20 md:py-28">
    <div class="container-premium grid lg:grid-cols-3 gap-12">
      <div class="lg:col-span-2">
        <p class="eyebrow">Reifenwechsel</p>
        <h2 class="mt-4 font-serif-display text-3xl md:text-5xl font-bold">
          Schnell. Sauber.<br />
          <span class="text-gold">Mit System.</span>
        </h2>
        <span class="gold-line"></span>
        <p class="text-gray-700 max-w-2xl">
          Reifenwechsel ist Routine - bei uns aber keine Massenabfertigung. Jede
          Felge wird sauber behandelt, jeder Reifen mit Drehmoment angezogen und
          ausgewuchtet. Termine werden eingehalten, Wartezeiten sind kurz.
        </p>

        <div class="mt-10 grid gap-3 sm:grid-cols-3">
          <div class="border-l-2 border-gold pl-4">
            <p class="font-serif-display text-3xl font-bold text-gold">&lt; 30</p>
            <p class="text-xs uppercase tracking-[0.2em] text-gray-700">Minuten Wechselzeit</p>
          </div>
          <div class="border-l-2 border-gold pl-4">
            <p class="font-serif-display text-3xl font-bold text-gold">Sa</p>
            <p class="text-xs uppercase tracking-[0.2em] text-gray-700">auch samstags geöffnet</p>
          </div>
          <div class="border-l-2 border-gold pl-4">
            <p class="font-serif-display text-3xl font-bold text-gold">★ 4.8</p>
            <p class="text-xs uppercase tracking-[0.2em] text-gray-700">Google-Bewertung</p>
          </div>
        </div>
      </div>

      <aside class="bg-white border border-[#E8E0D3] p-8">
        <p class="eyebrow">Saisonaler Hinweis</p>
        <p class="mt-4 font-serif-display text-2xl font-bold">
          Saisonwechsel?<br /><span class="text-gold">Rechtzeitig Termin sichern.</span>
        </p>
        <span class="gold-line"></span>
        <p class="text-sm text-gray-700">
          In den Wochen rund um O bis O (Oktober bis Ostern) ist die Nachfrage hoch.
          Termin vorab vereinbaren spart Wartezeit.
        </p>
        <a
          href={site.whatsapp}
          target="_blank"
          rel="noopener"
          class="btn-secondary mt-6 w-full"
        >
          Termin sichern
        </a>
      </aside>
    </div>
  </section>

  <section class="bg-white py-20 md:py-28">
    <div class="container-premium">
      <div class="max-w-2xl">
        <p class="eyebrow">Leistungen</p>
        <h2 class="mt-4 font-serif-display text-3xl md:text-5xl font-bold">
          Reifen-Service.<br /><span class="text-gold">Komplett.</span>
        </h2>
        <span class="gold-line"></span>
      </div>

      <div class="mt-14 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {
          services.map((s) => (
            <article class="premium-card">
              <p class="text-gold text-xs uppercase tracking-[0.25em]">Reifen</p>
              <h3 class="mt-3 font-serif-display text-2xl font-bold">{s.title}</h3>
              <span class="gold-line"></span>
              <p class="text-gray-700">{s.text}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="anthracite-bg py-20 md:py-28">
    <div class="container-premium max-w-3xl mx-auto text-center">
      <p class="eyebrow text-gold-light justify-center">Stimme aus dem Reifen-Geschäft</p>
      <p class="mt-6 font-serif-display text-2xl md:text-3xl text-cream italic leading-relaxed">
        "{reifenReview.quote}"
      </p>
      <span class="gold-line-centered"></span>
      <p class="text-xs uppercase tracking-[0.25em] text-gold">{reifenReview.author}</p>
    </div>
  </section>

  <CTAFooterBlock
    title="Reifen-Termin gewünscht?"
    subtitle="Saisonwechsel, neue Reifen oder Einlagerung - rufen Sie an oder schreiben Sie über WhatsApp."
  />
</Layout>
